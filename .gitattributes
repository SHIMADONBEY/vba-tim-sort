# Text / EOL for VBA sources
*.bas text eol=crlf
*.cls text eol=crlf
# Treat Excel binary as binary
*.xlsb binary
# Exclude developer, CI and large non-release dirs from git-archive
/.github/** export-ignore
/.vscode/** export-ignore
/.idea/** export-ignore
/logs/** export-ignore
/xvba_modules/** export-ignore
/xvba_unit_test/** export-ignore
/ribbons/examples/** export-ignore
/ribbons/images/** export-ignore
/node_modules/** export-ignore
/vba-files/test/** export-ignore
# Exclude repo config and dev manifests (not needed in release zip)
package.json export-ignore
package-lock.json export-ignore
/config.json export-ignore
# Keep docs, license, core logic, and test-runner by NOT marking them export-ignore:
# - README.md, README.ja.md, LICENSE, SECURITY*.md, THIRD_PARTY_NOTICES.md
# - vba-files/ (core logic only; vba-files/test/** is excluded above)
# - test-runner.xlsb (Excel Integration Examples)
test-runner.xlsb filter=lfs diff=lfs merge=lfs -text
